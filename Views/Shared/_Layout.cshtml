<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Đặt Vé Xe</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/WebDatVeXe.styles.css" />
</head>
<body>

<nav class="navbar navbar-expand-md site-navbar">
    <div class="container">
        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
            <span class="brand-icon"><i class="fa-solid fa-bus"></i></span>
            ĐặtVéXe
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-house me-1"></i>Trang chủ
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Ve" asp-action="VeCuaToi">
                        <i class="fa-solid fa-ticket me-1"></i>Vé của tôi
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="LienHe" asp-action="Index">
                        <i class="fa-solid fa-envelope me-1"></i>Liên hệ
                    </a>
                </li>
            </ul>
            <partial name="_LoginPartial" />
        </div>
    </div>
</nav>

@if (TempData["Success"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-success d-flex align-items-center gap-2">
            <i class="fa-solid fa-circle-check"></i>
            @TempData["Success"]
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-danger d-flex align-items-center gap-2">
            <i class="fa-solid fa-circle-exclamation"></i>
            @TempData["Error"]
        </div>
    </div>
}

<main role="main">
    @RenderBody()
</main>

<footer class="site-footer">
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-4 mb-md-0">
                <div class="footer-brand">
                    <i class="fa-solid fa-bus me-2"></i>ĐặtVéXe
                </div>
                <p class="footer-desc">Nền tảng đặt vé xe khách trực tuyến nhanh chóng, tiện lợi và giá tốt nhất.</p>
            </div>
            <div class="col-md-2 mb-4 mb-md-0">
                <h6>Dịch vụ</h6>
                <ul class="footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Tìm chuyến xe</a></li>
                    <li><a asp-controller="Ve" asp-action="VeCuaToi">Vé của tôi</a></li>
                    <li><a asp-controller="LienHe" asp-action="Index">Liên hệ</a></li>
                </ul>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <h6>Hỗ trợ</h6>
                <ul class="footer-links">
                    <li><a asp-controller="HoTro" asp-action="Index">Trung tâm hỗ trợ</a></li>
                    <li><a href="#">Chính sách hoàn vé</a></li>
                    <li><a href="#">Điều khoản sử dụng</a></li>
                </ul>
            </div>
            <div class="col-md-3">
                <h6>Liên hệ</h6>
                <ul class="footer-links">
                    <li><i class="fa-solid fa-phone me-2"></i>1900 xxxx</li>
                    <li><i class="fa-solid fa-envelope me-2"></i>support&#64;datvexe.vn</li>
                    <li class="mt-2 d-flex gap-2">
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle" style="width:32px;height:32px;padding:0;display:flex;align-items:center;justify-content:center;"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-light rounded-circle" style="width:32px;height:32px;padding:0;display:flex;align-items:center;justify-content:center;"><i class="fab fa-youtube"></i></a>
                    </li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>&copy; 2026 ĐặtVéXe — Dự án học .NET MVC + EF Core</span>
            <span>Made with <i class="fa-solid fa-heart text-danger"></i> in Vietnam</span>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
