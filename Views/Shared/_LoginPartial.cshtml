@using Microsoft.AspNetCore.Identity
@using WebDatVeXe.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Admin" asp-controller="Home" asp-action="Index">Quản trị</a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Ve" asp-action="VeCuaToi">Vé của tôi</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="HoTro" asp-action="Index">Hỗ trợ</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Tài khoản">Xin chào @User.Identity?.Name!</a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link text-dark">Đăng xuất</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
    </li>
    <li class="nav-item ms-1 d-flex align-items-center">
        <a class="btn btn-primary btn-sm px-3 py-2" style="font-weight:700;border-radius:8px;"
           asp-area="Identity" asp-page="/Account/Login">
            <i class="fa-solid fa-right-to-bracket me-1"></i>Đăng nhập
        </a>
    </li>
}
</ul>
